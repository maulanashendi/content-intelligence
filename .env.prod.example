# Copy to .env.prod (gitignored) and fill in real values.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# --- Postgres (local container — remove this whole block + the `postgres`
# service in docker-compose.prod.yml once the DB moves external, then set
# DATABASE_URL below directly to the external host) ---
POSTGRES_DB=editor_intelligence
POSTGRES_USER=app
POSTGRES_PASSWORD=

# Overrides the constructed postgres:// URL above. Leave unset while using
# the local `postgres` service; set explicitly once the DB is external.
# DATABASE_URL=postgresql+asyncpg://user:pass@external-host:5432/editor_intelligence

# --- Analyst (api service) ---
ANALYST_LLM_PROVIDER=openai
ANALYST_LLM_API_KEY=
# ANALYST_LLM_BASE_URL=
# ANALYST_ANALYZE_MODEL=gpt-4o
# ANALYST_RECOMMEND_MODEL=gpt-4o

# --- Embedding + labeling (pipeline-daemon / pipeline, OpenRouter by default) ---
EMBEDDING_API_KEY=
LABELING_LLM_API_KEY=

# --- Optional overrides (defaults shown) ---
# LOG_LEVEL=INFO
# TIMEZONE=Asia/Jakarta
# CLUSTER_SCHEDULE_HOUR=6
# CLUSTER_SCHEDULE_MINUTE=0
# CLUSTERING_WINDOW_DAYS=7
# EMBEDDING_PROVIDER=api
# LABELING_PROVIDER=api

# --- Caddy (reverse proxy) ---
# Ships serving plain HTTP on :80 (IP-only, no TLS). Caddyfile env-var
# substitution has no bash-style ":-default" fallback, so a domain can't be
# injected via env var here — for automatic HTTPS, edit Caddyfile directly
# and replace ":80" with your real domain (e.g. "yourdomain.com").
