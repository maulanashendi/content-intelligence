# Production environment template. Copy to `.env.prod` and fill in real values.
# Compose loads this file with: docker compose --env-file backend/.env.prod -f docker-compose.prod.yml ...
#
# DO NOT commit `.env.prod`. Only this `.example` file is checked in.

# --- Postgres credentials (required, no defaults) ---
POSTGRES_DB=editor_intelligence
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Application logging ---
LOG_LEVEL=INFO

# --- Ingest tuning ---
INGEST_TIMEOUT_SECONDS=30
TIMEZONE=Asia/Jakarta
