# Database
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/editor_intelligence

# Logging
LOG_LEVEL=INFO

# ML model identifiers (HuggingFace Hub)
EMBEDDING_MODEL_NAME=google/embeddinggemma-300m
EMBEDDING_MODEL_VERSION=
LLM_MODEL_NAME=google/gemma-2-2b-it
LLM_MODEL_VERSION=

# HuggingFace cache directory
HF_HOME=/models

# Clustering parameters
CLUSTERING_WINDOW_DAYS=30
HDBSCAN_MIN_CLUSTER_SIZE=5
UMAP_RANDOM_STATE=42
UMAP_TARGET_DIMENSIONS=30

# Ingestion
INGEST_TIMEOUT_SECONDS=30

# Pipeline scheduling
TIMEZONE=Asia/Jakarta
