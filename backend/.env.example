# Docker Compose project name — keeps volume names stable regardless of working directory
COMPOSE_PROJECT_NAME=editor-intelligence

# Database
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5433/editor_intelligence

# Test database — pytest creates and migrates this DB on first run, then
# truncates between tests. MUST differ from DATABASE_URL or tests refuse to
# run. Defaults to <DATABASE_URL>_test when unset.
# TEST_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5433/editor_intelligence_test

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# ML model identifiers (HuggingFace Hub)
EMBEDDING_MODEL_NAME=google/embeddinggemma-300m
EMBEDDING_MODEL_VERSION=
LLM_MODEL_NAME=bartowski/gemma-2-2b-it-GGUF
LLM_MODEL_VERSION=

# HuggingFace — token required for gated models (e.g. google/embeddinggemma-300m)
# Generate at huggingface.co/settings/tokens (read scope is sufficient)
HF_TOKEN=
HF_HOME=/models

# Clustering parameters
CLUSTERING_WINDOW_DAYS=7
HDBSCAN_MIN_CLUSTER_SIZE=5
UMAP_RANDOM_STATE=42
UMAP_TARGET_DIMENSIONS=30

# Google Search Console — service account JSON relative to backend/
# GSC_SITE_URL: sc-domain:<domain> for domain property, https://... for URL-prefix property
GOOGLE_APPLICATION_CREDENTIALS=teco-analytics-2cea1d43461c.json
GSC_SITE_URL=sc-domain:tempo.co
GSC_CREDENTIALS_PATH=teco-analytics-2cea1d43461c.json
GSC_FETCH_DAYS=7

# Ingestion
INGEST_TIMEOUT_SECONDS=30

# Pipeline scheduling — daemon-internal scheduler fires cluster+label daily
# at this local time, in TIMEZONE. Manual API triggers remain available.
TIMEZONE=Asia/Jakarta
CLUSTER_SCHEDULE_HOUR=6
CLUSTER_SCHEDULE_MINUTE=0

# Scoring thresholds — cluster_insight raw signals (D27)
GSC_UNDERPERFORM_IMPRESSIONS_MIN=100
GSC_UNDERPERFORM_POSITION_MIN=10.0
GSC_UNDERPERFORM_CTR_MAX=0.02
SCORING_RECENT_INTERNAL_DAYS=7
SCORING_MORNING_TOP_N=10
SCORING_DEFERRED_VELOCITY_MIN=0.4

# --- Editorial AI Analyst (D37) ---
# Switch vendor by name; base_url + headers come from the preset table in
# analyst/providers.py. Presets: openai | openrouter | ollama | vllm
ANALYST_LLM_PROVIDER=openai
ANALYST_LLM_API_KEY=
# Optional: override the preset base_url (required for self-hosted ollama/vllm host:port).
ANALYST_LLM_BASE_URL=
# Model ids are vendor-specific. OpenRouter uses "vendor/model", e.g. openai/gpt-4o.
ANALYST_ANALYZE_MODEL=gpt-4o
ANALYST_RECOMMEND_MODEL=gpt-4o
# Optional OpenRouter attribution headers:
ANALYST_ATTRIBUTION_REFERER=
ANALYST_ATTRIBUTION_TITLE=
#
# OpenRouter example:
#   ANALYST_LLM_PROVIDER=openrouter
#   ANALYST_LLM_API_KEY=sk-or-...
#   ANALYST_ANALYZE_MODEL=openai/gpt-4o
#   ANALYST_RECOMMEND_MODEL=openai/gpt-4o
